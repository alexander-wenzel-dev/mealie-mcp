MEALIE_BASE_URL=https://mealie.example.com
MEALIE_API_TOKEN=replace-me

# Transport: stdio (default) or http. stdio needs none of the settings below.
MEALIE_MCP_TRANSPORT=stdio
# HTTP transport refuses to start without a token. Generate with scripts/gen-token.
MEALIE_MCP_HTTP_TOKEN=
MEALIE_MCP_HTTP_HOST=127.0.0.1
MEALIE_MCP_HTTP_PORT=8000
MEALIE_MCP_HTTP_ALLOWED_HOSTS=127.0.0.1,localhost
